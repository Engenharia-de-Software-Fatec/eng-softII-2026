@startuml
top to bottom direction

actor Administrador
actor Cliente
actor Contador

rectangle "Sistema Contabilidade Ágil" {

  usecase "Gerenciar sistema" as GS
  usecase "Gerenciar usuários" as GU

  usecase "Enviar documentos" as ED

  usecase "Gerenciar clientes" as GC

  usecase "Revisar lançamentos" as RL

  usecase "Aprovar lançamentos" as AL
  usecase "Corrigir lançamentos" as CL

  usecase "Gerenciar documentos" as GD

  Administrador --> GS

  Cliente --> ED

  Contador --> ED
  Contador --> GC
  Contador --> RL
  Contador --> GD

  GS .> GU : <<include>>

  RL .> AL : <<extend>>
  RL .> CL : <<extend>>

}

@enduml
