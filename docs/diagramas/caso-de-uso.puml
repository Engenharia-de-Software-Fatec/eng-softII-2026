@startuml
left to right direction

actor Cliente
actor Contador
actor IA

rectangle "Sistema Contabilidade Ágil" {

  Cliente --> (Enviar arquivos)

  Contador --> (Enviar arquivos)
  Contador --> (Revisar lançamentos contábeis)
  Contador --> (Revisar lançamentos)
  Contador -- (Gerenciar clientes)
  Contador -- (Gerenciar documentos)

  IA --> (Realizar lançamentos contábeis)

  (Revisar lançamentos) .> (Aprovar lançamentos) : <<extend>>
  (Revisar lançamentos) .> (Corrigir lançamentos) : <<extend>>

  (Realizar lançamentos contábeis) .> (Revisar lançamentos) : <<include>>
}

@enduml
