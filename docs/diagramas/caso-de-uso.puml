@startuml
left to right direction
skinparam packageStyle rectangle

actor Cliente
actor Contador
actor IA

rectangle "Sistema Contabilidade Ágil" {

  (Enviar arquivos) as Upload
  (Gerenciar clientes) as Clientes
  (Gerenciar documentos) as ManageDocs
  (Realizar lançamentos contábeis) as Lançamentos
  (Revisar lançamentos) as Review
  (Aprovar lançamentos) as Aprove
  (Corrigir lançamentos) as toCorrect
}

Cliente --> Upload
Contador --> Upload
Contador --> Clientes
Contador --> ManageDocs
Contador --> Lançamentos
Contador --> Review
IA --> Lançamentos

Review --> Aprove
Review --> toCorrect
Review --> Lançamentos

@enduml
