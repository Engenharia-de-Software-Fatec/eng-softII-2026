@startuml
title Diagrama de Classes - Contabilidade Ágil

skinparam classAttributeIconSize 0
skinparam style strictuml

' ========================
' USUÁRIOS
' ========================
abstract class Usuario {
  - id: UUID
  - nome: String
  - email: String
  - senhaHash: String
  - ativo: Boolean
  - criadoEm: DateTime
  - atualizadoEm: DateTime
}

class Cliente {
}

class Contador {
  - crc: String
}

class Administrador {
}

Usuario <|-- Cliente
Usuario <|-- Contador
Usuario <|-- Administrador

' ========================
' EMPRESA
' ========================
class Empresa {
  - id: UUID
  - razaoSocial: String
  - nomeFantasia: String
  - cnpj: String
  - criadoEm: DateTime
}

Cliente "*" --> "1" Empresa : representa >

' ========================
' DOCUMENTOS
' ========================
class Documento {
  - id: UUID
  - titulo: String
  - categoria: CategoriaDocumento
  - dataUpload: DateTime
  - status: StatusDocumento
  - criadoEm: DateTime
}

enum CategoriaDocumento {
  NOTA_FISCAL
  RECIBO
  EXTRATO_BANCARIO
  BOLETO
  FOLHA_PAGAMENTO
  OUTRO
}

enum StatusDocumento {
  PENDENTE
  PROCESSANDO
  ANALISADO
  REJEITADO
}

class Arquivo {
  - id: UUID
  - nomeOriginal: String
  - mimeType: String
  - tamanhoBytes: Long
  - urlStorage: String
}

Empresa "1" *-- "0..*" Documento
Usuario "1" --> "0..*" Documento : realizaUpload >
Documento "1" *-- "1" Arquivo

' ========================
' IA / PROCESSAMENTO
' ========================
class MotorIA {
}

class ModeloIA {
  - id: UUID
  - nome: String
  - versao: String
  - provider: String
}

class AnaliseDocumento {
  - id: UUID
  - confianca: Decimal
  - dataAnalise: DateTime
  - status: StatusAnalise
}

enum StatusAnalise {
  SUCESSO
  ERRO
  BAIXA_CONFIANCA
}

Documento "1" --> "0..*" AnaliseDocumento
MotorIA "1" --> "0..*" AnaliseDocumento : gera >
AnaliseDocumento "*" --> "1" ModeloIA

' ========================
' LANÇAMENTOS CONTÁBEIS
' ========================
class LancamentoContabil {
  - id: UUID
  - dataLancamento: Date
  - descricao: String
  - status: StatusLancamento
  - criadoEm: DateTime
}

enum StatusLancamento {
  PENDENTE_APROVACAO
  APROVADO
  CORRIGIDO
  REJEITADO
}

class ItemLancamento {
  - id: UUID
  - valor: Decimal
  - tipo: TipoMovimento
}

enum TipoMovimento {
  DEBITO
  CREDITO
}

class ContaContabil {
  - codigo: String
  - nome: String
  - tipo: TipoConta
}

enum TipoConta {
  ATIVO
  PASSIVO
  RECEITA
  DESPESA
  PATRIMONIO
}

AnaliseDocumento "1" --> "1..*" LancamentoContabil : gera >
LancamentoContabil "1" *-- "2..*" ItemLancamento
ItemLancamento "*" --> "1" ContaContabil

Empresa "1" -- "0..*" LancamentoContabil
LancamentoContabil "*" --> "1" Documento

Contador "1" -- "0..*" LancamentoContabil : revisa >

' ========================
' REVISÃO CONTÁBIL
' ========================
class RevisaoContabil {
  - id: UUID
  - observacao: String
  - dataRevisao: DateTime
}

LancamentoContabil "1" -- "0..*" RevisaoContabil
RevisaoContabil "*" --> "1" AnaliseDocumento : referencia >
Contador "1" -- "0..*" RevisaoContabil : registra >

' ========================
' RELATÓRIOS
' ========================
class Relatorio {
  - id: UUID
  - tipo: TipoRelatorio
  - dataGeracao: DateTime
}

enum TipoRelatorio {
  BALANCETE
  DRE
  RAZAO
  DIARIO
}

Relatorio "1" --> "0..*" LancamentoContabil
Contador "1" -- "0..*" Relatorio
Administrador "1" -- "0..*" Relatorio

@enduml
