@startuml
title Diagrama de Classes - Contabilidade Ágil

skinparam classAttributeIconSize 0
skinparam style strictuml
skinparam monochrome false

' =========================
' CLASSES PRINCIPAIS
' =========================

abstract class Usuario {
  - id: UUID
  - nome: String
  - email: String
  - senhaHash: String
  - ativo: Boolean
  + login()
  + logout()
}

class Cliente {
  - empresa: String
  - cnpj: String
  + enviarDocumento()
  + acompanharStatus()
}

class Contador {
  - crc: String
  + aprovarLancamento()
  + corrigirLancamento()
  + gerarRelatorio()
}

class Administrador {
  + gerenciarUsuarios()
  + configurarSistema()
}

Usuario <|-- Cliente
Usuario <|-- Contador
Usuario <|-- Administrador

' =========================
' DOCUMENTOS
' =========================

class Documento {
  - id: UUID
  - nomeArquivo: String
  - tipo: String
  - dataUpload: DateTime
  - status: StatusDocumento
  + validarArquivo()
  + armazenar()
}

enum StatusDocumento {
  PENDENTE
  PROCESSANDO
  ANALISADO
  REJEITADO
}

Cliente "1" -- "0..*" Documento : envia >

' =========================
' IA / PROCESSAMENTO
' =========================

class MotorIA {
  + extrairDados()
  + classificarDocumento()
  + sugerirLancamentos()
}

class AnaliseDocumento {
  - id: UUID
  - confianca: Decimal
  - dataAnalise: DateTime
  + processar()
}

Documento "1" -- "1" AnaliseDocumento
MotorIA ..> AnaliseDocumento

' =========================
' LANÇAMENTOS CONTÁBEIS
' =========================

class LancamentoContabil {
  - id: UUID
  - dataLancamento: Date
  - descricao: String
  - valor: Decimal
  - status: StatusLancamento
  + validar()
}

enum StatusLancamento {
  PENDENTE_APROVACAO
  APROVADO
  CORRIGIDO
  REJEITADO
}

class ContaContabil {
  - codigo: String
  - nome: String
  - tipo: String
}

AnaliseDocumento "1" -- "1..*" LancamentoContabil : gera >
LancamentoContabil "*" --> "1" ContaContabil : débito
LancamentoContabil "*" --> "1" ContaContabil : crédito

Contador "1" -- "0..*" LancamentoContabil : revisa >

' =========================
' FEEDBACK / APRENDIZADO
' =========================

class CorrecaoIA {
  - id: UUID
  - observacao: String
  - dataCorrecao: DateTime
}

LancamentoContabil "1" -- "0..1" CorrecaoIA
Contador "1" -- "0..*" CorrecaoIA : registra >

' =========================
' RELATÓRIOS
' =========================

class Relatorio {
  - id: UUID
  - tipo: String
  - dataGeracao: DateTime
  + exportarPDF()
  + exportarExcel()
}

Contador "1" -- "0..*" Relatorio
Administrador "1" -- "0..*" Relatorio

@enduml