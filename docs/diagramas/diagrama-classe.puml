@startuml
title Diagrama de Classes

skinparam classAttributeIconSize 0
skinparam style strictuml

' ========================
' USUÁRIOS
' ========================
abstract class Usuario {
  - id: UUID
  - nome: String
  - email: String
  - senhaHash: String
  - ativo: Boolean
  
  
}

class Cliente {
  - empresa: String
  - cnpj: String
  
}

class Contador {
  - crc: String
 
}

class Administrador {
  
}

Usuario <|-- Cliente
Usuario <|-- Contador
Usuario <|-- Administrador

' ========================
' DOCUMENTOS
' ========================
class Documento {
  - id: UUID
  - nomeArquivo: String
  - tipo: String
  - dataUpload: DateTime
  - status: StatusDocumento

}

enum StatusDocumento {
  PENDENTE
  PROCESSANDO
  ANALISADO
  REJEITADO
}

Cliente "1" -- "0..*" Documento : envia >

' ========================
' IA / PROCESSAMENTO
' ========================
class MotorIA {

}

class AnaliseDocumento {
  - id: UUID
  - confianca: Decimal
  - dataAnalise: DateTime
  - status: StatusAnalise
  
}

enum StatusAnalise {
  SUCESSO
  ERRO
  BAIXA_CONFIANCA
}

Documento "1" *-- "1" AnaliseDocumento
MotorIA "1" --> "0..*" AnaliseDocumento : gera >

' ========================
' LANÇAMENTOS CONTÁBEIS
' ========================
class LancamentoContabil {
  - id: UUID
  - dataLancamento: Date
  - descricao: String
  - status: StatusLancamento

}

enum StatusLancamento {
  PENDENTE_APROVACAO
  APROVADO
  CORRIGIDO
  REJEITADO
}

class ItemLancamento {
  - id: UUID
  - valor: Decimal
  - tipo: TipoMovimento
}

enum TipoMovimento {
  DEBITO
  CREDITO
}

class ContaContabil {
  - codigo: String
  - nome: String
  - tipo: String
}

' Relações contábeis corretas
AnaliseDocumento "1" -- "1..*" LancamentoContabil : gera >
LancamentoContabil "1" *-- "2..*" ItemLancamento
ItemLancamento "*" --> "1" ContaContabil

' Rastreabilidade (IMPORTANTE)
LancamentoContabil "*" --> "1" Documento

' Revisão do contador
Contador "1" -- "0..*" LancamentoContabil : revisa >

' ========================
' FEEDBACK / APRENDIZADO
' ========================
class CorrecaoIA {
  - id: UUID
  - observacao: String
  - dataCorrecao: DateTime
}

LancamentoContabil "1" -- "0..1" CorrecaoIA
CorrecaoIA "*" --> "1" LancamentoContabil : altera >
CorrecaoIA "*" --> "1" AnaliseDocumento : melhora >

Contador "1" -- "0..*" CorrecaoIA : registra >

' ========================
' RELATÓRIOS
' ========================
class Relatorio {
  - id: UUID
  - tipo: String
  - dataGeracao: DateTime
  
}

Relatorio "1" --> "0..*" LancamentoContabil
Contador "1" -- "0..*" Relatorio
Administrador "1" -- "0..*" Relatorio

@enduml
